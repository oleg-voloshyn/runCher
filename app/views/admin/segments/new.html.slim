- content_for :page_title, t('admin.segments.new_title')

.max-w-lg
  .bg-white.rounded-xl.shadow-sm.border.border-gray-200.p-6
    p.text-sm.text-gray-500.mb-5
      = t('admin.segments.new_description_html').html_safe

    = form_with url: admin_segments_path, method: :post do |f|
      .space-y-4
        div
          label.block.text-sm.font-medium.text-gray-700.mb-1 = t('admin.segments.id_label')
          = text_field_tag 'segment[strava_id]', nil, placeholder: t('admin.segments.id_placeholder'),
              class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 font-mono"
        .flex.items-center.gap-3
          = f.submit t('admin.segments.fetch_and_save'), class: "bg-orange-500 hover:bg-orange-600 text-white text-sm font-medium px-5 py-2.5 rounded-lg cursor-pointer transition-colors"
          = link_to t('admin.shared.cancel'), admin_segments_path, class: "text-sm text-gray-500 hover:text-gray-700"
