<% content_for :page_title, "Турніри" %>

<div class="flex items-center justify-between mb-6">
  <p class="text-sm text-gray-500"><%= @tournaments.size %> турнірів</p>
  <%= link_to "＋ Новий турнір", new_admin_tournament_path, class: "bg-orange-500 hover:bg-orange-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-gray-50 border-b border-gray-100 text-left">
        <th class="px-6 py-3 font-semibold text-gray-600">Назва</th>
        <th class="px-6 py-3 font-semibold text-gray-600">Статус</th>
        <th class="px-6 py-3 font-semibold text-gray-600">Сегменти</th>
        <th class="px-6 py-3 font-semibold text-gray-600">Учасники</th>
        <th class="px-6 py-3 font-semibold text-gray-600">Дати</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% @tournaments.each do |t| %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4">
            <%= link_to t.name, admin_tournament_path(t), class: "font-medium text-gray-900 hover:text-orange-500" %>
            <p class="text-xs text-gray-400 mt-0.5 truncate max-w-xs"><%= t.description %></p>
          </td>
          <td class="px-6 py-4"><%= status_badge(t.status) %></td>
          <td class="px-6 py-4">
            <span class="text-gray-900"><%= t.total_segments_count %> всього</span>
            <span class="text-gray-400">/ <%= t.rated_segments_count %> рейтинг.</span>
          </td>
          <td class="px-6 py-4 text-gray-700"><%= t.tournament_participants.size %></td>
          <td class="px-6 py-4 text-gray-500 text-xs">
            <% if t.starts_at %>
              <%= t.starts_at.strftime('%d.%m.%Y') %>
              <% if t.ends_at %> — <%= t.ends_at.strftime('%d.%m.%Y') %><% end %>
            <% else %>
              —
            <% end %>
          </td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "Деталі", admin_tournament_path(t), class: "text-xs text-gray-500 hover:text-gray-800" %>
              <%= link_to "Редагувати", edit_admin_tournament_path(t), class: "text-xs text-blue-500 hover:text-blue-700" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @tournaments.empty? %>
        <tr><td colspan="6" class="px-6 py-10 text-center text-gray-400">Немає турнірів. <%= link_to "Створити перший", new_admin_tournament_path, class: "text-orange-500 hover:underline" %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
